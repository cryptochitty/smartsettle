# ─────────────────────────────────────────────────────────────────────────────
# SmartSettle — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Wallet ────────────────────────────────────────────────────────────────────
# Private key of the deployer / agent wallet (no 0x prefix needed by Hardhat)
PRIVATE_KEY=your_private_key_here

# ── Celo Sepolia Testnet (primary testnet — replaces Alfajores) ───────────────
# Chain ID  : 11142220 (0xAA044C)
# Faucet    : https://faucet.celo.org/celo-sepolia
# Explorer  : https://celo-sepolia.blockscout.com
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# ── Celo Mainnet ──────────────────────────────────────────────────────────────
# Chain ID  : 42220
# cUSD addr : 0x765DE816845861e75A25fCA122bb6898B8B1282a
CELO_MAINNET_RPC_URL=https://forno.celo.org

# ── Contract Verification ─────────────────────────────────────────────────────
# Get your key at https://celoscan.io/myapikey
CELOSCAN_API_KEY=your_celoscan_api_key_here

# ── AI / Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Deployed Contract Addresses (filled in after deploy) ─────────────────────
MOCK_CUSD_ADDRESS=
RECEIPT_STORE_ADDRESS=
AGENT_WALLET_ADDRESS=
SMART_SETTLE_ADDRESS=

# ── Agent Config ──────────────────────────────────────────────────────────────
# Maximum cUSD the agent can spend per transaction (in USD, e.g. 500)
AGENT_MAX_PER_TX_USD=500
# Maximum cUSD the agent can spend per day (in USD)
AGENT_MAX_DAILY_USD=5000

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_CHAIN_ID=11142220
NEXT_PUBLIC_NETWORK_NAME=celoSepolia
DRY_RUN=true
LOG_LEVEL=debug
